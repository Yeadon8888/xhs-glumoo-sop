# Portable paths (edit for the target machine)
XHS_WORKSPACE_WORKER=~/openclaw-xhs-worker
XHS_DAILY_OUT_BASE=~/Glumoo/02_每日内容生成
XHS_REF_DIR=~/Glumoo/产品资料/产品照/三款产品

# Default Yunwu text generation config (fill your own key)
XHS_TEXT_API_KEY=REPLACE_WITH_YOUR_YUNWU_TEXT_KEY
XHS_TEXT_BASE_URL=https://yunwu.ai
XHS_TEXT_MODEL=models/gemini-3.1-flash-lite-preview

# Default Yunwu image generation config (fill your own key)
XHS_IMAGE_API_KEY=REPLACE_WITH_YOUR_YUNWU_IMAGE_KEY
XHS_IMAGE_BASE_URL=https://yunwu.ai
XHS_IMAGE_MODEL=gemini-3.1-flash-image-preview
XHS_IMAGE_ASPECT_RATIO=4:5

# Optional fallback for official Gemini
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# GEMINI_BASE_URL=
# GEMINI_MODEL=

# Optional: only needed if you want publish flow later
# XHS_MCP_CONFIG=$XHS_WORKSPACE_WORKER/config/mcporter.json
